<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title>Spora Scan Live</title>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        body { background: #07111f; color: white; font-family: sans-serif; text-align: center; margin: 0; padding: 20px; }
        #reader { width: 100%; max-width: 400px; margin: auto; border: 2px solid #2fc95c; border-radius: 12px; overflow: hidden; }
        button { background: #2fc95c; border: none; padding: 15px; border-radius: 10px; font-weight: bold; width: 80%; margin-top: 20px; }
    </style>
</head>
<body>
    <h2>SPORA SCAN</h2>
    <div id="reader"></div>
    <button onclick="arrancar()">ACTIVAR CÁMARA</button>
    <p id="resultado">Esperando código...</p>

    <script>
        let scanner = new Html5Qrcode("reader");
        function arrancar() {
            scanner.start({ facingMode: "environment" }, { fps: 20, qrbox: 250 },
                (txt) => { 
                    document.getElementById('resultado').innerText = "LEÍDO: " + txt;
                    // Aquí después conectamos con tu Google Script
                },
                () => {}
            ).catch(err => alert("Error: " + err));
        }
    </script>
</body>
</html>
